---
---
<section class="section news-section" id="news">
  <div class="container">
    <div class="section-header reveal">
      <h2 class="section-title">In the <span class="text-gradient">News</span></h2>
      <p class="section-subtitle">A global impact in neuro-rehabilitation through viral surgery stories and life-transforming news.</p>
    </div>

    <div class="news-list">
      <!-- Story 1 -->
      <article class="news-item reveal">
        <div class="news-image-box">
          <img src="/images/news_surgery.png" alt="Surgery" class="news-img" />
          <div class="news-category">VIRAL STORY</div>
        </div>
        <div class="news-content">
          <h3 class="news-title">Performing a Vo Thalamotomy for a Guitarist Dystonia</h3>
          <p class="news-text">
            The news went viral world over and got millions of views within 24Hrs. A proud moment for all Indians, showcasing clinical excellence captured in real-time.
          </p>
          <div class="news-meta">
            <span class="news-date">A Proud National Moment</span>
            <a href="#" class="news-link">View Full Story <span>→</span></a>
          </div>
        </div>
      </article>

      <!-- Story 2 -->
      <article class="news-item reveal-delay-2 reveal">
        <div class="news-image-box">
          <img src="/images/news_team.png" alt="Medical Team" class="news-img" />
          <div class="news-category">SUCCESS STORY</div>
        </div>
        <div class="news-content">
          <h3 class="news-title">Full Circle of Hope: Sarah Gomez's Journey</h3>
          <p class="news-text">
            From a sudden stroke survivor to a neurosurgeon-in-training at the very hospital that saved her. Her inspiring journey shows the power of resilience and expert care.
          </p>
          <div class="news-meta">
             <div class="news-btns">
                <a href="#" class="btn-sm">Read Story</a>
                <a href="#" class="btn-sm outline">View More</a>
             </div>
             <a href="#" class="news-link">The Inspiring Journey <span>→</span></a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .news-section {
    background: #ffffff;
  }

  .section-header {
    margin-bottom: 60px;
    max-width: 600px;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .news-item {
    display: flex;
    background: var(--bg-slate);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: var(--transition-smooth);
    border: 1px solid rgba(0,0,0,0.05);
  }

  .news-item:hover {
    transform: translateX(10px);
    box-shadow: var(--shadow-premium);
    background: white;
    border-color: var(--primary-color);
  }

  .news-image-box {
    flex: 0 0 350px;
    position: relative;
    overflow: hidden;
  }

  .news-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .news-item:hover .news-img {
    transform: scale(1.05);
  }

  .news-category {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--premium-gradient);
    color: white;
    padding: 4px 12px;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 4px;
    letter-spacing: 1px;
  }

  .news-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
  }

  .news-title {
    font-size: 1.8rem;
    margin-bottom: 16px;
    line-height: 1.3;
    color: var(--text-main);
  }

  .news-text {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 32px;
    line-height: 1.7;
  }

  .news-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .news-date {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary-color);
  }

  .news-link {
    font-weight: 700;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.3s;
  }

  .news-link:hover {
    gap: 12px;
    color: var(--primary-color);
  }

  .news-btns {
    display: flex;
    gap: 12px;
  }

  .btn-sm {
    padding: 8px 20px;
    background: var(--primary-color);
    color: white;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: 0.3s;
  }

  .btn-sm.outline {
    background: transparent;
    color: var(--primary-color);
    border: 1px solid var(--primary-color);
  }

  .btn-sm:hover {
    opacity: 0.8;
  }

  @media (max-width: 992px) {
    .news-item {
      flex-direction: column;
    }
    .news-image-box {
      flex: 0 0 250px;
    }
    .news-item:hover {
       transform: translateY(-10px);
    }
  }

  @media (max-width: 768px) {
    .news-title { font-size: 1.5rem; }
  }
</style>
