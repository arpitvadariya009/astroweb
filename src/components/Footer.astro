---
---
<footer class="footer" id="appointment">
  <div class="container footer-top">
    <div class="footer-brand">
       <div class="logo">
          <span class="logo-circle">S</span>
          <div class="logo-text">
            <span class="dr-title">Dr. Sharan</span>
            <span class="dr-name">Srinivasan</span>
          </div>
       </div>
       <p class="brand-tagline">Clinician. Innovator. Author. Champion for Functional Recovery.</p>
       <p class="brand-desc">
          Co-Founder & CMD of <strong>PRS Neurosciences</strong> and <strong>Newro Kaaya Innovative Solutions</strong>, Bengaluru. Leading Stereotactic & Functional Neurosurgeon dedicated to clinical excellence, affordable innovation, and restoring human dignity — one patient at a time.
       </p>
       <div class="brand-oath">
          "If it doesn't help our patients get better, we're simply not interested."
       </div>
    </div>

    <div class="footer-links">
       <h4 class="footer-h">Quick Links</h4>
       <ul class="f-list">
          <li><a href="#about">About Dr. Sharan</a></li>
          <li><a href="#mission">Mission & Vision</a></li>
          <li><a href="#news">Media & News</a></li>
          <li><a href="#interests">Areas of Excellence</a></li>
          <li><a href="#patents">Global Patents & IP</a></li>
          <li><a href="#media">Books & Media</a></li>
          <li><a href="#testimonials">Patient Stories</a></li>
       </ul>
    </div>

    <div class="footer-cta">
        <h4 class="footer-h">Consultation</h4>
        <p>Expert neurological consultation available on request. Specializing in functional neurosurgery, neuromodulation, and advanced neurorehabilitation.</p>
        <a href="mailto:contact@prsneurosciences.com" class="btn-premium mt-4">Book Consultation</a>
        <div class="contact-items">
          <div class="contact-item">
            <span class="ci-icon">📍</span>
            <span>Bengaluru, Karnataka, India</span>
          </div>
          <div class="contact-item">
            <span class="ci-icon">🏥</span>
            <span>PRS Neurosciences & Mechatronics Research Institute</span>
          </div>
        </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container fb-container">
       <p>&copy; {new Date().getFullYear()} Dr. Sharan Srinivasan · PRS Neurosciences. All Rights Reserved.</p>
       <div class="social-links">
          <a href="#" class="s-icon" aria-label="LinkedIn">in</a>
          <a href="#" class="s-icon" aria-label="Twitter/X">𝕏</a>
          <a href="#" class="s-icon" aria-label="YouTube">▶</a>
          <a href="#" class="s-icon" aria-label="Instagram">ig</a>
       </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f172a;
    color: white;
    padding: 100px 0 0;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 0.9fr 1.2fr;
    gap: 64px;
    padding-bottom: 80px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .logo-circle {
    width: 48px;
    height: 48px;
    background: var(--premium-gradient);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    font-size: 1.8rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .logo-text { line-height: 1; }
  .dr-title { font-size: 0.85rem; opacity: 0.6; color: white; display: block; }
  .dr-name { font-size: 1.25rem; font-weight: 800; color: white; display: block; }

  .brand-tagline {
    font-size: 0.82rem;
    color: var(--accent-color);
    font-weight: 700;
    letter-spacing: 0.5px;
    margin-bottom: 14px;
    text-transform: uppercase;
  }

  .brand-desc {
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.75;
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .brand-desc strong { color: rgba(255,255,255,0.8); }

  .brand-oath {
    font-size: 0.88rem;
    font-style: italic;
    color: rgba(255,255,255,0.4);
    border-left: 2px solid rgba(79,70,229,0.5);
    padding-left: 14px;
    line-height: 1.6;
  }

  .footer-h {
    font-size: 1.1rem;
    margin-bottom: 24px;
    color: white;
    font-weight: 700;
  }

  .f-list { list-style: none; }
  .f-list li { margin-bottom: 10px; }
  .f-list a {
    color: rgba(255, 255, 255, 0.5);
    transition: 0.3s;
    font-size: 0.92rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .f-list a::before { content: '→'; font-size: 0.78rem; opacity: 0; transform: translateX(-6px); transition: 0.3s; }
  .f-list a:hover { color: var(--accent-color); padding-left: 4px; }
  .f-list a:hover::before { opacity: 1; transform: translateX(0); }

  .footer-cta p {
     color: rgba(255, 255, 255, 0.5);
     margin-bottom: 20px;
     font-size: 0.92rem;
     line-height: 1.7;
  }

  .mt-4 { margin-top: 0; }

  .contact-items {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }

  .ci-icon { flex-shrink: 0; margin-top: 1px; }

  .footer-bottom {
    background: rgba(0, 0, 0, 0.25);
    padding: 28px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .fb-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .fb-container p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .social-links {
    display: flex;
    gap: 10px;
  }

  .s-icon {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 800;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    transition: 0.3s;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .s-icon:hover {
    background: var(--primary-color);
    color: white;
    transform: translateY(-3px);
    border-color: transparent;
  }

  @media (max-width: 1100px) {
    .footer-top { gap: 48px; }
  }

  @media (max-width: 992px) {
    .footer-top {
       grid-template-columns: 1fr 1fr;
       gap: 48px;
    }
    .footer-brand { grid-column: span 2; }
  }

  @media (max-width: 768px) {
    .footer-top {
       grid-template-columns: 1fr;
       gap: 40px;
       padding-bottom: 60px;
    }
    .footer-brand { grid-column: span 1; }
    .footer { padding-top: 72px; }
  }

  @media (max-width: 480px) {
    .fb-container {
       flex-direction: column;
       gap: 16px;
       text-align: center;
    }
    .logo-circle { width: 40px; height: 40px; font-size: 1.4rem; }
  }
</style>
